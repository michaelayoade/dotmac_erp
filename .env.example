# =============================================================================
# Dotmac ERP Configuration
# =============================================================================
# Copy this file to .env and configure for your environment.
# For production, use OpenBao for secrets management (see below).
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# For Docker: Use db:5432 (internal network)
# For local dev: Use localhost:5435 (exposed port from docker-compose)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5435/dotmac_erp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dotmac_erp

# Connection pool settings (adjust for your workload)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_PASSWORD=redis
REDIS_URL=redis://:redis@localhost:6380/0
CELERY_BROKER_URL=redis://:redis@localhost:6380/0
CELERY_RESULT_BACKEND=redis://:redis@localhost:6380/1
CELERY_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# Authentication - REQUIRED SECRETS
# -----------------------------------------------------------------------------
# These are REQUIRED for the application to start.
# Option 1: Direct values (development only!)
# Option 2: OpenBao references (recommended for production)
#
# Generate JWT_SECRET:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Generate TOTP_ENCRYPTION_KEY:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# OpenBao reference format:
#   JWT_SECRET=bao://secret/dotmac#jwt_secret
#   TOTP_ENCRYPTION_KEY=bao://secret/dotmac#totp_key
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30
TOTP_ISSUER=dotmac_erp
TOTP_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Cookie Security
# -----------------------------------------------------------------------------
# PRODUCTION: Set REFRESH_COOKIE_SECURE=true and SAMESITE=strict
# Development defaults below are for local testing only
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_PATH=/

# -----------------------------------------------------------------------------
# OpenBao / Vault Configuration (Secrets Management)
# -----------------------------------------------------------------------------
# Enable OpenBao for production secrets management.
# When configured, secrets can reference OpenBao using URI format:
#   bao://mount/path#field
#   openbao://mount/path#field
#   vault://mount/path#field
#
# Example: JWT_SECRET=bao://secret/dotmac#jwt_secret
# -----------------------------------------------------------------------------
OPENBAO_ADDR=http://localhost:8200
OPENBAO_TOKEN=devtoken
OPENBAO_NAMESPACE=
OPENBAO_KV_VERSION=2
# Allow non-HTTPS connections (dev only, never in production!)
OPENBAO_ALLOW_INSECURE=false

# -----------------------------------------------------------------------------
# Branding
# -----------------------------------------------------------------------------
BRAND_NAME=Dotmac ERP
BRAND_TAGLINE=Unified ERP for finance, HR, and operations
BRAND_LOGO_URL=
BRAND_MARK=
DEFAULT_FUNCTIONAL_CURRENCY_CODE=NGN
DEFAULT_PRESENTATION_CURRENCY_CODE=NGN

# -----------------------------------------------------------------------------
# Landing Page Content
# -----------------------------------------------------------------------------
LANDING_HERO_BADGE=Dotmac ERP
LANDING_HERO_TITLE=Run your entire business on one ERP
LANDING_HERO_SUBTITLE=Finance, HR, and operations with real-time reporting.
LANDING_CTA_PRIMARY=Get started
LANDING_CTA_SECONDARY=Explore modules
LANDING_CONTENT_JSON=

# -----------------------------------------------------------------------------
# Celery Scheduler
# -----------------------------------------------------------------------------
CELERY_BEAT_MAX_LOOP_INTERVAL=5
CELERY_BEAT_REFRESH_SECONDS=30

# -----------------------------------------------------------------------------
# Observability (OpenTelemetry)
# -----------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME=dotmac_erp
OTEL_EXPORTER_OTLP_ENDPOINT=

# -----------------------------------------------------------------------------
# Gunicorn (Production)
# -----------------------------------------------------------------------------
GUNICORN_BIND=0.0.0.0:8002
GUNICORN_WORKERS=
GUNICORN_LOG_LEVEL=info
